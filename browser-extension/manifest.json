{
  "manifest_version": 3,
  "name": "Center",
  "version": "1.0.0",
  "description": "ADHD work tracker that predicts distraction patterns and enforces focus.",
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"] 
    }
  ],
  "permissions": [
    "tabs",      
    "storage",   
    "scripting"  
  ],
  "host_permissions": [
    "<all_urls>" 
  ]
}